# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/football_analytics?schema=public"

# Aplicacion
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT - cambiar estos valores en produccion
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL=7d

# CORS - origen del frontend
CORS_ORIGIN=http://localhost:4200
