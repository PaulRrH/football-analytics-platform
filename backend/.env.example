# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/football_analytics?schema=public"

# Aplicacion
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# CORS - origen del frontend
CORS_ORIGIN=http://localhost:4200

# Autenticacion JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Usuario admin inicial (seed) - opcional, valores de desarrollo por defecto
SEED_ADMIN_EMAIL=admin@worldcup-analytics.local
SEED_ADMIN_PASSWORD=Admin123!

# Proveedor de datos externos (football-data.org) - opcional
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
